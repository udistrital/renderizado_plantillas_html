{
  "swagger": "2.0",
  "info": {
    "description": "API para la generación de PDFs a partir de plantillas HTML.",
    "version": "1.0.0",
    "title": "PDF Generation API"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "tags": [
    {
      "name": "PDF Generation",
      "description": "Operaciones relacionadas con la generación de PDF."
    }
  ],
  "schemes": [
    "http"
  ],
  "paths": {
    "/generar-docx": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": {
              "properties": {
                "css": {
                  "description": "Optional CSS string.",
                  "type": "string"
                },
                "data": {
                  "description": "Optional data for Jinja2 templating.",
                  "type": "object"
                },
                "html": {
                  "description": "The HTML template string.",
                  "type": "string"
                }
              },
              "required": [
                "html"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DOCX generated successfully",
            "schema": {
              "properties": {
                "Data": {
                  "description": "Base64 encoded DOCX string",
                  "type": "string"
                },
                "Message": {
                  "type": "string"
                },
                "Status": {
                  "type": "integer"
                },
                "Success": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          },
          "500": {
            "description": "Error generating DOCX",
            "schema": {
              "properties": {
                "Message": {
                  "type": "string"
                },
                "Status": {
                  "type": "integer"
                },
                "Success": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Genera un DOCX a partir de un HTML.",
        "tags": [
          "DOCX Generation"
        ]
      }
    },
    "/generar-html": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": {
              "properties": {
                "datos": {
                  "description": "Optional data for Jinja2 templating.",
                  "type": "object"
                },
                "html": {
                  "description": "The HTML template string.",
                  "type": "string"
                }
              },
              "required": [
                "html"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "HTML generated successfully",
            "schema": {
              "properties": {
                "Data": {
                  "description": "Rendered HTML with variables replaced",
                  "type": "string"
                },
                "Message": {
                  "type": "string"
                },
                "Status": {
                  "type": "integer"
                },
                "Success": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          },
          "500": {
            "description": "Error generating HTML",
            "schema": {
              "properties": {
                "Message": {
                  "type": "string"
                },
                "Status": {
                  "type": "integer"
                },
                "Success": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Genera un HTML a partir de un HTML.",
        "tags": [
          "HTML Generation"
        ]
      }
    },
    "/generar-pdf": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "schema": {
              "properties": {
                "css": {
                  "description": "Optional CSS string.",
                  "type": "string"
                },
                "data": {
                  "description": "Optional data for Jinja2 templating.",
                  "type": "object"
                },
                "html": {
                  "description": "The HTML template string.",
                  "type": "string"
                }
              },
              "required": [
                "html"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PDF generated successfully",
            "schema": {
              "properties": {
                "Data": {
                  "description": "Base64 encoded PDF string",
                  "type": "string"
                },
                "Message": {
                  "type": "string"
                },
                "Status": {
                  "type": "integer"
                },
                "Success": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          },
          "500": {
            "description": "Error generating PDF",
            "schema": {
              "properties": {
                "Message": {
                  "type": "string"
                },
                "Status": {
                  "type": "integer"
                },
                "Success": {
                  "type": "boolean"
                }
              },
              "type": "object"
            }
          }
        },
        "summary": "Genera un PDF a partir de un HTML.",
        "tags": [
          "PDF Generation"
        ]
      }
    }
  }
}